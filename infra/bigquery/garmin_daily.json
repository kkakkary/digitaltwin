      {"name": "dose", "type": "STRING", "mode": "NULLABLE", "description": "Dose, e.g. '500mg', '2 tablets'"}
    ]},
  {"name": "raw",              "type": "JSON",   "mode": "NULLABLE", "description": "Full per-metric Garmin payloads for this day (lossless, future-proof)"}
