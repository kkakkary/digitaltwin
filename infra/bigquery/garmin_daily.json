[
  {"name": "user_id",          "type": "STRING", "mode": "REQUIRED", "description": "Which person this day belongs to"},
  {"name": "date",             "type": "DATE",   "mode": "REQUIRED", "description": "Calendar date (local)"},
  {"name": "total_steps",      "type": "INTEGER","mode": "NULLABLE"},
  {"name": "resting_hr",       "type": "INTEGER","mode": "NULLABLE"},
  {"name": "avg_stress",       "type": "INTEGER","mode": "NULLABLE"},
  {"name": "body_battery_high","type": "INTEGER","mode": "NULLABLE"},
  {"name": "body_battery_low", "type": "INTEGER","mode": "NULLABLE"},
  {"name": "sleep_seconds",    "type": "INTEGER","mode": "NULLABLE"},
  {"name": "deep_sleep_seconds","type":"INTEGER","mode": "NULLABLE"},
  {"name": "rem_sleep_seconds","type": "INTEGER","mode": "NULLABLE"},
  {"name": "hrv_avg",          "type": "INTEGER","mode": "NULLABLE", "description": "HRV status avg (populates after several nights of wear)"},
  {"name": "total_kcal",       "type": "INTEGER","mode": "NULLABLE"},
  {"name": "active_kcal",      "type": "INTEGER","mode": "NULLABLE"},
  {"name": "weight_lbs",       "type": "FLOAT",  "mode": "NULLABLE", "description": "Body weight in pounds, from Garmin body composition (smart scale or manual log)"},
  {"name": "medications",      "type": "RECORD", "mode": "REPEATED", "description": "Medications taken this day (manually logged; not from Garmin). Preserved across daily re-syncs.",
    "fields": [
