# LibreLinkUp COLLECTOR account credentials.
# This is a dedicated email that all sensor wearers 
# have shared their LibreLink data with via the LibreLinkUp follower app.
# Setup (one-time, per sensor wearer):
#   LibreLink app → Profile → Connected Apps → LibreLinkUp → Invite → <collector email>
# .env is gitignored and must never be committed.
LIBRE_EMAIL=
LIBRE_PASSWORD=

# Optional overrides:
# Abbott server region — "us" or "eu" (default: us)
# LIBRE_REGION=us
# Print full raw API responses to discover endpoints/data shape (default: off)
# LIBRE_DISCOVER=1
# Explicit firstName → user_id mapping (default: firstName.lower())
# LIBRE_USER_MAP=Christian:christian,Kevin:kevin,Vince:vincent
