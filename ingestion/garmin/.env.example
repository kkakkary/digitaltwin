# Copy this file to .env and fill in your real Garmin Connect credentials.
# .env is gitignored and must never be committed.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Optional overrides:
# Number of days back to pull (default 7)
# DAYS_BACK=7
# Where the auth token is cached (default ~/.garminconnect)
# GARMIN_TOKENSTORE=~/.garminconnect
